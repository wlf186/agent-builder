{
  "config": {
    "default": true,
    // Generated user-guide pages preserve source annotation spacing, and
    // retained legacy reports are not reformatted solely for whitespace.
    "MD012": false,
    "MD013": false,
    "MD022": false,
    "MD024": { "siblings_only": true },
    "MD025": { "front_matter_title": "" },
    "MD031": false,
    "MD032": false,
    "MD033": false,
    "MD036": false,
    "MD040": false,
    "MD041": false,
    "MD060": false
  },
  "globs": [
    "README.md",
    "AGENTS.md",
    "CLAUDE.md",
    "CONTRIBUTING.md",
    "SECURITY.md",
    "frontend/README.md",
    "docs/**/*.md",
    "docs-site/**/*.md"
  ],
  "ignores": [
    "docs/superpowers/**",
    "docs-site/node_modules/**",
    "docs-site/.vitepress/cache/**",
    "docs-site/.vitepress/dist/**"
  ]
}
